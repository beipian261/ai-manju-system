<!DOCTYPE html>
<html class="light" lang="zh-CN">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>AI 漫剧系统</title>
</head>
<body class="antialiased" style="margin:0; padding:0; font-family: var(--font-family); color: var(--color-text); background: var(--color-bg);">

  <!-- ===== NAV ===== -->
  <nav class="sticky top-0 z-50" style="background: rgba(255,255,255,0.7); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px); border-bottom: 1px solid rgba(226,232,240,0.5);">
    <div class="max-w-6xl mx-auto flex items-center justify-between" style="padding: 16px 24px;">
      <!-- Logo -->
      <div class="flex items-center gap-3">
        <div class="flex items-center justify-center" style="width:32px; height:32px; border-radius: var(--radius-md); background: var(--gradient-primary);">
          <span style="color:#fff; font-weight:700; font-size:16px; line-height:1;">A</span>
        </div>
        <span style="font-weight:600; font-size:16px; color: var(--color-text);">AI 漫剧</span>
      </div>
      <!-- Right -->
      <div class="flex items-center gap-6">
        <a href="#" class="hidden sm:inline-flex whitespace-nowrap" style="font-size: var(--font-size-sm); color: var(--color-text-secondary); transition: color 200ms ease; text-decoration:none;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'">功能</a>
        <a href="#" class="hidden sm:inline-flex whitespace-nowrap" style="font-size: var(--font-size-sm); color: var(--color-text-secondary); transition: color 200ms ease; text-decoration:none;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'">定价</a>
        <a href="#" class="hidden sm:inline-flex whitespace-nowrap" style="font-size: var(--font-size-sm); color: var(--color-text-secondary); transition: color 200ms ease; text-decoration:none;" onmouseover="this.style.color='var(--color-text)'" onmouseout="this.style.color='var(--color-text-secondary)'">文档</a>
        <button data-dom-id="nav-dashboard" class="inline-flex items-center justify-center whitespace-nowrap" style="background: var(--gradient-primary); color:#fff; border:none; border-radius: var(--radius-button); font-size: var(--font-size-sm); font-weight:500; padding: 8px 16px; cursor:pointer; box-shadow: var(--shadow-button); transition: transform 200ms ease, box-shadow 200ms ease;" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='var(--shadow-button-lg)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-button)'">
          开始使用
        </button>
      </div>
    </div>
  </nav>

  <main>

    <!-- ===== HERO ===== -->
    <section class="relative flex items-center justify-center" style="min-height:80vh; background: linear-gradient(135deg, #0F172A 0%, #1E293B 50%, #0F172A 100%); overflow:hidden;">
      <!-- Glow -->
      <div class="absolute inset-0 pointer-events-none" style="background: radial-gradient(ellipse at 50% 0%, rgba(16,185,129,0.12) 0%, transparent 60%);"></div>
      <!-- Content -->
      <div class="relative z-10 text-center max-w-3xl mx-auto" style="padding: 0 24px;">
        <!-- Badge -->
        <div class="inline-flex items-center justify-center whitespace-nowrap" style="border-radius: var(--radius-full); padding: 6px 16px; font-size: var(--font-size-xs); font-weight:500; background: rgba(16,185,129,0.15); color: #34D399; border: 1px solid rgba(16,185,129,0.2);">
          AI 驱动的新一代创作工具
        </div>
        <!-- H1 -->
        <h1 style="margin-top:24px; font-size: clamp(36px, 5vw, 60px); font-weight:700; color:#fff; line-height:1.15; letter-spacing:-0.02em; text-wrap:balance; word-break:keep-all; overflow-wrap:break-word;">
          把你的故事变成<span style="background: linear-gradient(135deg, #34D399, #06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text;">漫剧</span>
        </h1>
        <!-- Subtitle -->
        <p style="margin-top:24px; font-size:18px; color: rgba(203,213,225,1); max-width:560px; margin-left:auto; margin-right:auto; line-height:1.6;">
          从创意到成片，AI 全程辅助。写剧本、创角色、画分镜、合成配音，一站式完成你的漫剧创作。
        </p>
        <!-- CTAs -->
        <div class="flex flex-col sm:flex-row items-center justify-center gap-4" style="margin-top:32px;">
          <button data-dom-id="cta-start" class="inline-flex items-center justify-center whitespace-nowrap" style="background: var(--gradient-primary); color:#fff; border:none; border-radius: var(--radius-button); font-size: var(--font-size-sm); font-weight:600; padding: 12px 24px; cursor:pointer; box-shadow: var(--shadow-button-lg); transition: transform 200ms ease, box-shadow 300ms ease;" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='var(--shadow-glow)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-button-lg)'">
            免费开始创作
          </button>
          <button class="inline-flex items-center justify-center gap-2 whitespace-nowrap" style="background:transparent; color: rgba(203,213,225,1); border:1px solid rgba(255,255,255,0.2); border-radius: var(--radius-button); font-size: var(--font-size-sm); font-weight:500; padding: 12px 24px; cursor:pointer; transition: border-color 200ms ease, background 200ms ease;" onmouseover="this.style.borderColor='rgba(255,255,255,0.4)'; this.style.background='rgba(255,255,255,0.05)'" onmouseout="this.style.borderColor='rgba(255,255,255,0.2)'; this.style.background='transparent'">
            <i data-lucide="play" style="width:16px; height:16px;"></i>
            观看演示
          </button>
        </div>
      </div>
    </section>

    <!-- ===== FEATURES ===== -->
    <section style="background: var(--color-bg); padding: 96px 24px;">
      <div class="max-w-5xl mx-auto">
        <!-- Section heading -->
        <p style="text-align:center; font-size: var(--font-size-xs); font-weight:600; color: var(--color-text-muted); letter-spacing:0.1em; text-transform:uppercase; margin-bottom:16px;">核心能力</p>
        <h2 style="text-align:center; font-size: clamp(22px, 2.4vw, 32px); font-weight:700; color: var(--color-text); margin-bottom:64px; text-wrap:balance; word-break:keep-all; overflow-wrap:break-word;">让 AI 成为你的创作搭档</h2>
        <!-- Cards -->
        <div class="grid grid-cols-1 md:grid-cols-3 gap-6">
          <!-- Card 1 -->
          <div class="group" style="background:#fff; border-radius:14px; border:1px solid var(--color-border); padding:32px; box-shadow: var(--shadow-card); transition: transform 300ms ease, box-shadow 300ms ease; cursor:default;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-card-hover)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-card)'">
            <div class="flex items-center justify-center" style="width:48px; height:48px; border-radius: var(--radius-md); background: var(--gradient-primary-soft);">
              <i data-lucide="pen-tool" style="width:22px; height:22px; color: var(--brand-primary);"></i>
            </div>
            <h3 style="margin-top:20px; margin-bottom:8px; font-size:18px; font-weight:600; color: var(--color-text);">智能剧本</h3>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height:1.625;">输入创意灵感，AI 自动生成结构完整的漫剧剧本，支持多轮修改和风格调整。</p>
          </div>
          <!-- Card 2 -->
          <div class="group" style="background:#fff; border-radius:14px; border:1px solid var(--color-border); padding:32px; box-shadow: var(--shadow-card); transition: transform 300ms ease, box-shadow 300ms ease; cursor:default;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-card-hover)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-card)'">
            <div class="flex items-center justify-center" style="width:48px; height:48px; border-radius: var(--radius-md); background: var(--gradient-primary-soft);">
              <i data-lucide="users" style="width:22px; height:22px; color: var(--brand-primary);"></i>
            </div>
            <h3 style="margin-top:20px; margin-bottom:8px; font-size:18px; font-weight:600; color: var(--color-text);">角色一致性</h3>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height:1.625;">创建角色后，AI 在所有场景中保持角色外观和性格的一致性，无需手动逐帧调整。</p>
          </div>
          <!-- Card 3 -->
          <div class="group" style="background:#fff; border-radius:14px; border:1px solid var(--color-border); padding:32px; box-shadow: var(--shadow-card); transition: transform 300ms ease, box-shadow 300ms ease; cursor:default;" onmouseover="this.style.transform='translateY(-2px)'; this.style.boxShadow='var(--shadow-card-hover)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-card)'">
            <div class="flex items-center justify-center" style="width:48px; height:48px; border-radius: var(--radius-md); background: var(--gradient-primary-soft);">
              <i data-lucide="film" style="width:22px; height:22px; color: var(--brand-primary);"></i>
            </div>
            <h3 style="margin-top:20px; margin-bottom:8px; font-size:18px; font-weight:600; color: var(--color-text);">一键成片</h3>
            <p style="font-size: var(--font-size-sm); color: var(--color-text-secondary); line-height:1.625;">从分镜到配音到合成，AI 自动完成全部后期流程，你只需点击发布。</p>
          </div>
        </div>
      </div>
    </section>

    <!-- ===== SOCIAL PROOF ===== -->
    <section style="background: var(--color-bg-subtle); padding: 64px 24px;">
      <div class="max-w-4xl mx-auto grid grid-cols-1 sm:grid-cols-3 gap-10 text-center">
        <div>
          <div style="font-size: clamp(28px, 3vw, 36px); font-weight:700; background: linear-gradient(135deg, #34D399, #06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; font-variant-numeric:tabular-nums; white-space:nowrap;">10,000+</div>
          <p style="margin-top:4px; font-size: var(--font-size-sm); color: var(--color-text-secondary);">创作者</p>
        </div>
        <div>
          <div style="font-size: clamp(28px, 3vw, 36px); font-weight:700; background: linear-gradient(135deg, #34D399, #06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; font-variant-numeric:tabular-nums; white-space:nowrap;">50,000+</div>
          <p style="margin-top:4px; font-size: var(--font-size-sm); color: var(--color-text-secondary);">作品生成</p>
        </div>
        <div>
          <div style="font-size: clamp(28px, 3vw, 36px); font-weight:700; background: linear-gradient(135deg, #34D399, #06B6D4); -webkit-background-clip:text; -webkit-text-fill-color:transparent; background-clip:text; font-variant-numeric:tabular-nums; white-space:nowrap;">98%</div>
          <p style="margin-top:4px; font-size: var(--font-size-sm); color: var(--color-text-secondary);">好评率</p>
        </div>
      </div>
    </section>

    <!-- ===== CTA ===== -->
    <section style="padding: 80px 24px; text-align:center;">
      <h2 style="font-size: clamp(22px, 2.4vw, 32px); font-weight:700; color: var(--color-text); text-wrap:balance; word-break:keep-all; overflow-wrap:break-word;">准备好开始了吗？</h2>
      <p style="margin-top:8px; font-size: var(--font-size-sm); color: var(--color-text-secondary);">加入万千创作者，用 AI 释放你的创意</p>
      <div style="margin-top:24px;">
        <button data-dom-id="cta-bottom" class="inline-flex items-center justify-center whitespace-nowrap" style="background: var(--gradient-primary); color:#fff; border:none; border-radius: var(--radius-button); font-size: var(--font-size-sm); font-weight:600; padding: 12px 24px; cursor:pointer; box-shadow: var(--shadow-button-lg); transition: transform 200ms ease, box-shadow 300ms ease;" onmouseover="this.style.transform='translateY(-1px)'; this.style.boxShadow='var(--shadow-glow)'" onmouseout="this.style.transform='translateY(0)'; this.style.boxShadow='var(--shadow-button-lg)'">
          免费开始
        </button>
      </div>
    </section>

  </main>

  <!-- ===== FOOTER ===== -->
  <footer style="border-top:1px solid var(--color-border); padding:32px 24px;">
    <div class="max-w-6xl mx-auto flex items-center justify-between">
      <span style="font-size: var(--font-size-xs); color: var(--color-text-muted);">&copy; 2026 AI 漫剧系统</span>
      <span style="font-size: var(--font-size-xs); color: var(--color-text-muted);">隐私政策 &middot; 服务条款</span>
    </div>
  </footer>

  <script>lucide.createIcons();</script>
</body>
</html>

    </style>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4.3.1/dist/index.global.js"></script>
