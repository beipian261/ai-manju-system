# ============================================================
# AI Comic Drama System — 环境变量模板
# ============================================================
# 使用方法：cp .env.example .env，然后填入真实值
# 
# 优先级规则（从高到低）：
#   1. 数据库 Setting 表（通过 /dashboard/settings 页面设置）
#   2. 环境变量（.env 或 docker-compose environment）
#   3. 代码默认值（见注释）
# 
# 注意：Settings 页面保存后，环境变量默认值将被数据库值覆盖。
#       仅 Settings 白名单中的 key 受此影响（见 src/lib/settings.ts）。
# ============================================================

# ── 必需（至少填一个）──────────────────────────────
# Agnes AI API 密钥（申请地址：https://platform.agnes-ai.com）
AGNES_API_KEY=sk-your-key-here

# ── 鉴权（至少填一个，否则开发模式下无需鉴权）────────────────
# 明文密码（生产环境建议用下面的 HASH 替代）
AUTH_PASSWORD=your-secure-password

# bcrypt 哈希密码（优先级高于明文，安全性更高）
# 在 Node.js 中生成：node -e "console.log(require('bcryptjs').hashSync('your-password',10))"
# AUTH_PASSWORD_HASH=$2a$10$...

# HMAC-SHA256 Session 签名密钥（自动生成 signKey-{random}，但重启会变化）
# 生产环境强烈建议固定此值，否则重启后所有用户需重新登录
# 生成方式：node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# AUTH_SECRET=auto-generated-signing-key

# ── Agnes AI 平台配置（可选，有默认值）───────────────
# API Base URL（默认: https://apihub.agnes-ai.com/v1）
AGNES_API_BASE=https://apihub.agnes-ai.com/v1

# 文本模型（默认: agnes-2.0-flash）
AGNES_TEXT_MODEL=agnes-2.0-flash

# 图片生成模型（默认: agnes-image-2.1-flash）
AGNES_IMAGE_MODEL=agnes-image-2.1-flash

# 视频生成模型（默认: agnes-video-v2.0）
AGNES_VIDEO_MODEL=agnes-video-v2.0

# ── 图片生成调优（可选，有默认值）───────────────────
# 单张图片最大重试次数（默认: 3，数据库覆盖: IMAGE_MAX_RETRIES）
IMAGE_MAX_RETRIES=4

# 图片质量评估阈值 0-100（默认: 60，数据库覆盖: IMAGE_EVAL_THRESHOLD）
# 提高此值 → 更严格的质量筛选 → 可能更多重试
IMAGE_EVAL_THRESHOLD=65

# ── 服务器配置 ─────────────────────────────────────
# 应用端口（docker-compose 默认 3000，本地开发 3001）
APP_PORT=3000

# 运行环境（production / development）
NODE_ENV=production

# 禁用 Next.js 遥测（可选，建议保留）
NEXT_TELEMETRY_DISABLED=1

# ── 安全提示 ───────────────────────────────────────
# 1. 不要将 .env 提交到 Git（已在 .gitignore 中）
# 2. 生产环境务必使用 AUTH_PASSWORD_HASH 而非明文密码
# 3. AUTH_SECRET 固定后可避免重启导致全员登出
# 4. API Key 请勿分享，可在 Settings 页面随时更换
