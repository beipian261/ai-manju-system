# ==============================
# AI Comic Drama System — Production Env Template
# Copy to .env and fill in your values
# ==============================

# --- Required ---
AGNES_API_KEY=sk-your-key-here

# --- Authentication (choose one) ---
AUTH_PASSWORD=your-secure-password
# AUTH_PASSWORD_HASH=  # bcrypt hash auto-generated on first login
# AUTH_SECRET=         # HMAC signing key (auto-generated if omitted)

# --- Agnes AI Platform ---
AGNES_API_BASE=https://platform.agnes-ai.com/v1
AGNES_TEXT_MODEL=agnes-2.0-flash
AGNES_IMAGE_MODEL=agnes-image-2.1-flash
AGNES_VIDEO_MODEL=agnes-video-v2.0

# --- Image Generation ---
IMAGE_MAX_RETRIES=4
IMAGE_HARD_TIMEOUT_MS=120000
IMAGE_EVAL_THRESHOLD=65

# --- Server ---
APP_PORT=3000
NODE_ENV=production
